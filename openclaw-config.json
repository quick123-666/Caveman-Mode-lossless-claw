{
  "plugins": {
    "entries": {
      "losslessClaw": {
        "config": {
          "contextThreshold": 0.6,
          "freshTailCount": 16,
          "incrementalMaxDepth": 5
        }
      }
    }
  },
  "agents": {
    "defaults": {
      "heartbeat": {
        "lightContext": true
      }
    }
  },
  "session": {
    "maintenance": {
      "rotateBytes": "1gb",
      "maxEntries": 1000000,
      "pruneAfter": "365d"
    }
  }
}